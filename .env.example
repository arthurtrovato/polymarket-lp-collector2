# Public market-data collector only. No wallet or Polymarket private key is used.
DATA_DIR=/var/lib/polymarket-collector
MAX_MARKETS=75
MIN_DAILY_REWARD=0
MIN_VOLUME_24H=0
DISCOVERY_INTERVAL_SECONDS=900
ROTATION_SECONDS=900
MAX_FILE_MIB=64
FLUSH_INTERVAL_SECONDS=2
HEALTH_HOST=127.0.0.1
HEALTH_PORT=8080
STALE_AFTER_SECONDS=180
LOG_LEVEL=INFO

# Optional Google Drive archive through rclone.
# Example after running `rclone config`: gdrive:polymarket-data
RCLONE_REMOTE=
LOCAL_RETENTION_DAYS=7
REMOVE_AFTER_UPLOAD=false
BACKUP_MIN_AGE=2m
